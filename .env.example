# --- Backend ---------------------------------------------------------------
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173

# Postgres + Redis
DATABASE_URL=postgres://cloudops:cloudops@localhost:5432/cloudops_jobs
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=7d

# --- Job sources -----------------------------------------------------------
# Phase 1: JSearch (recommended starter — aggregates LinkedIn/Indeed/Glassdoor/ZipRecruiter)
# Sign up at https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
RAPIDAPI_KEY=
RAPIDAPI_HOST=jsearch.p.rapidapi.com

# Phase 2 sources (optional)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# --- AI (resume tailoring, Phase 3) ---------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# --- Worker tuning ---------------------------------------------------------
SCRAPE_INTERVAL_MINUTES=180
SCRAPE_ON_BOOT=true

# --- Dev/demo mode ---------------------------------------------------------
# Set to true to seed the DB with sample jobs (run `npm run seed` instead — kept
# here for documentation).
USE_SEED_DATA=false

# --- Frontend (Vite) -------------------------------------------------------
VITE_API_URL=/api
